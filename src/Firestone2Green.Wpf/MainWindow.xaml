<Window x:Class="Firestone2Green.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Firestone2Green By Mer3y"
        Width="1180" Height="900"
        MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource HairlineBrush}"
        FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border Margin="1" Background="{StaticResource CanvasBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="FooterRow" Height="64"/>
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" Grid.Row="0" Background="{StaticResource CanvasBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border VerticalAlignment="Bottom" Height="1" Background="{StaticResource HairlineBrush}"/>
                <Grid Width="132" HorizontalAlignment="Right">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ChromeButtonStyle}" Content="—"
                            FontSize="15" ToolTip="最小化" Click="Minimize_Click"/>
                    <Button x:Name="MaximizeButton" Grid.Column="1" Style="{StaticResource ChromeButtonStyle}"
                            Content="□" FontSize="14" ToolTip="最大化或还原" Click="Maximize_Click"/>
                    <Button Grid.Column="2" Style="{StaticResource ChromeButtonStyle}" Content="×"
                            FontSize="18" ToolTip="关闭" Click="Close_Click"/>
                </Grid>
            </Grid>

            <ScrollViewer x:Name="Viewport" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Background="{StaticResource CanvasBrush}">
                <Grid x:Name="ContentRoot" Margin="20,12,20,10">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="HeroRow" Height="178"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="HeroCard" Grid.Row="0" Style="{StaticResource CardStyle}"
                            Margin="3" Padding="24,18,24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="HeroCopyColumn" Width="68*"/>
                                <ColumnDefinition x:Name="HeroSideColumn" Width="32*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition x:Name="HeroKickerRow" Height="18"/>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="HeroKicker" Grid.Row="0" Text="FIRESTONE LOCAL REPAIR"
                                           FontSize="11.3" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Grid.Row="1" Text="Firestone2Green" FontFamily="Georgia"
                                           FontSize="33.3" Foreground="{StaticResource InkBrush}" TextTrimming="None"/>
                                <TextBlock Grid.Row="2" Text="本地授权 By Mer3y" FontSize="13.3"
                                           Foreground="{StaticResource MutedBrush}"/>
                                <WrapPanel Grid.Row="3" VerticalAlignment="Top" Margin="0,2,0,0">
                                    <Border x:Name="AdminPill" Background="{StaticResource SurfaceSoftBrush}" CornerRadius="999" Padding="12,5" Margin="0,0,8,6"><TextBlock x:Name="AdminPillText" Text="管理员：检测中" FontSize="11.7" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/></Border>
                                    <Border x:Name="ScriptPill" Background="{StaticResource SurfaceSoftBrush}" CornerRadius="999" Padding="12,5" Margin="0,0,8,6"><TextBlock x:Name="ScriptPillText" Text="脚本：检测中" FontSize="11.7" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/></Border>
                                    <Border x:Name="AvatarPill" Background="{StaticResource SurfaceSoftBrush}" CornerRadius="999" Padding="12,5" Margin="0,0,8,6"><TextBlock x:Name="AvatarPillText" Text="头像：检测中" FontSize="11.7" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/></Border>
                                    <Border x:Name="PathPill" Background="{StaticResource SurfaceSoftBrush}" CornerRadius="999" Padding="12,5" Margin="0,0,8,6"><TextBlock x:Name="PathPillText" Text="路径：检测中" FontSize="11.7" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/></Border>
                                    <Border x:Name="StatusPill" Background="{StaticResource SurfaceSoftBrush}" CornerRadius="999" Padding="12,5" Margin="0,0,8,6"><TextBlock x:Name="StatusPillText" Text="就绪" FontSize="11.7" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/></Border>
                                </WrapPanel>
                            </Grid>
                            <Grid x:Name="HeroSide" Grid.Column="1">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="63*"/><ColumnDefinition Width="37*"/></Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="*"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{StaticResource CanvasBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" CornerRadius="8" Padding="10,3" Margin="0,0,8,6"><TextBlock Text="网络   AuthOnlyOnline" FontSize="12" FontWeight="Bold"/></Border>
                                    <Border Grid.Row="1" Background="{StaticResource CanvasBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" CornerRadius="8" Padding="10,3" Margin="0,0,8,6"><TextBlock Text="头像   内置注入" FontSize="12" FontWeight="Bold"/></Border>
                                    <Border Grid.Row="2" Background="{StaticResource CanvasBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" CornerRadius="8" Padding="10,3" Margin="0,0,8,6" Cursor="Hand" MouseLeftButtonUp="UpdateMetric_MouseLeftButtonUp"><TextBlock x:Name="UpdateMetricText" Text="更新   检查中" FontSize="12" FontWeight="Bold"/></Border>
                                </Grid>
                                <Border Grid.Column="1" Background="{StaticResource CanvasBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" CornerRadius="12" Padding="8" Margin="12,0,0,0"><Image x:Name="AvatarImage" Stretch="Uniform"/></Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid x:Name="MainLayout" Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="LeftColumn" Width="43*"/>
                            <ColumnDefinition x:Name="MainGapColumn" Width="0"/>
                            <ColumnDefinition x:Name="RightColumn" Width="57*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="MainRowOne" Height="*"/>
                            <RowDefinition x:Name="MainRowGap" Height="0"/>
                            <RowDefinition x:Name="MainRowTwo" Height="0"/>
                        </Grid.RowDefinitions>

                        <Grid x:Name="LeftPane" Grid.Column="0" Grid.Row="0" Margin="0,0,18,0">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="PrimaryRow" Height="158"/>
                                <RowDefinition x:Name="MaintenanceRow" Height="218"/>
                                <RowDefinition x:Name="ControlsRow" Height="*"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="PrimaryCard" Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,14" Padding="18,10">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="18"/><RowDefinition Height="30"/><RowDefinition Height="24"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <TextBlock Text="推荐操作" FontSize="11.3" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Grid.Row="1" Text="一键重启并授权" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="2" Text="本地授权、头像修复、网络恢复。" FontSize="12.5" Foreground="{StaticResource MutedBrush}"/>
                                    <Button x:Name="LaunchAuthButton" Grid.Row="3" Style="{StaticResource PrimaryButtonStyle}" Content="一键重启并授权" Margin="6,2" Click="LaunchAuthButton_Click"/>
                                </Grid>
                            </Border>

                            <Border x:Name="MaintenanceCard" Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,14" Padding="18,14">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="18"/><RowDefinition Height="28"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <TextBlock Text="持续化与打包" FontSize="11.3" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Grid.Row="1" Text="更新后也能快速恢复" FontSize="16" FontWeight="Bold"/>
                                    <Grid Grid.Row="3" Height="96" VerticalAlignment="Bottom">
                                        <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="48"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <Button x:Name="InstallTaskButton" Grid.Row="0" Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Content="安装持续修复" Click="InstallTaskButton_Click"/>
                                        <Button x:Name="RemoveTaskButton" Grid.Row="0" Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="移除持续修复" Click="RemoveTaskButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Content="打开目录" Click="OpenBaseDirectoryButton_Click"/>
                                        <Button x:Name="AdminRestartButton" Grid.Row="1" Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="管理员重启" Click="AdminRestartButton_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border x:Name="ControlsCard" Grid.Row="2" Style="{StaticResource CardStyle}" Padding="18,14">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="18"/><RowDefinition Height="28"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <TextBlock Text="精细控制" FontSize="11.3" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock Grid.Row="1" Text="按需刷新，不重做全部流程" FontSize="16" FontWeight="Bold"/>
                                    <Grid Grid.Row="3" Height="96" VerticalAlignment="Top">
                                        <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="48"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <Button x:Name="RefreshAuthButton" Grid.Row="0" Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Content="刷新授权+头像" Click="RefreshAuthButton_Click"/>
                                        <Button x:Name="RestoreOnlineButton" Grid.Row="0" Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="恢复全功能网络" Click="RestoreOnlineButton_Click"/>
                                        <Button x:Name="VerifyButton" Grid.Row="1" Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Content="验证状态" Click="VerifyButton_Click"/>
                                        <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="打开报告" Click="OpenReportsButton_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid x:Name="RightPane" Grid.Column="2" Grid.Row="0">
                            <Grid.RowDefinitions><RowDefinition x:Name="PathRow" Height="190"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border x:Name="PathCard" Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,14" Padding="22,16">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="22"/><RowDefinition Height="26"/><RowDefinition Height="48"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <TextBlock Text="路径设置" FontSize="11.3" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="PathDescription" Grid.Row="1" Text="选择 Overwolf 根目录，需直接包含 OverwolfLauncher.exe 或 Overwolf.exe。" FontSize="13.6" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Row="2" Background="{StaticResource CanvasBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" CornerRadius="14" Padding="12,8,12,6" Margin="0,2,0,6">
                                        <TextBox x:Name="OverwolfRootTextBox" BorderThickness="0" Background="Transparent" FontFamily="Consolas" FontSize="12.7" VerticalContentAlignment="Center" TextChanged="OverwolfRootTextBox_TextChanged"/>
                                    </Border>
                                    <Grid Grid.Row="3" Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <Button x:Name="AutoSearchButton" Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" Content="自动搜索" Click="AutoSearchButton_Click"/>
                                        <Button x:Name="SelectPathButton" Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="选择路径" Click="SelectPathButton_Click"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border x:Name="LogCard" Grid.Row="1" Style="{StaticResource CardStyle}" Padding="22,20,22,22">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition x:Name="LogHeaderRow" Height="44"/><RowDefinition Height="*"/><RowDefinition x:Name="LogFootRow" Height="30"/></Grid.RowDefinitions>
                                    <Grid Grid.Row="0"><Grid.ColumnDefinitions><ColumnDefinition Width="60*"/><ColumnDefinition Width="40*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="运行日志" FontSize="19.3" FontWeight="Bold"/>
                                        <TextBlock x:Name="LogHint" Grid.Column="1" Text="实时输出 · JSON 报告自动保存" FontSize="12" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border x:Name="LogViewportBorder" Grid.Row="1" MaxHeight="304"
                                            Background="{StaticResource SurfaceDarkBrush}"
                                            BorderBrush="{StaticResource SurfaceDarkElevatedBrush}" BorderThickness="1"
                                            CornerRadius="20" Padding="15,14">
                                        <TextBox x:Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                                 BorderThickness="0" Background="Transparent"
                                                 Foreground="{StaticResource OnDarkBrush}" CaretBrush="{StaticResource OnDarkBrush}"
                                                 FontFamily="Consolas" FontSize="13.3"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <TextBox.Resources>
                                                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DarkLogScrollBarStyle}"/>
                                            </TextBox.Resources>
                                        </TextBox>
                                    </Border>
                                    <TextBlock x:Name="LogFootnote" Grid.Row="2" Text="完成后如果套牌/数据仍不刷新，点“恢复全功能网络”再点“验证状态”。" FontSize="11.7" Foreground="{StaticResource MutedBrush}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <Border x:Name="FooterBar" Grid.Row="2" Background="{StaticResource SurfaceDarkBrush}" Padding="20,4,20,6">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition x:Name="FooterCopyColumn" Width="55*"/><ColumnDefinition x:Name="FooterActionsColumn" Width="45*"/></Grid.ColumnDefinitions>
                    <StackPanel x:Name="FooterCopy" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="本地运行 · 不修改 Firestone 签名文件 · 更新后重新执行一次即可" Foreground="{StaticResource OnDarkSoftBrush}" FontSize="11.7"/>
                        <TextBlock Text="完全免费，仅在 GitHub 发布；付费购买就是被骗了。帮到你欢迎点 Star。" Foreground="{StaticResource OnDarkBrush}" FontSize="11.7" FontWeight="Bold"/>
                    </StackPanel>
                    <Grid x:Name="FooterActions" Grid.Column="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="25*"/><ColumnDefinition Width="39*"/><ColumnDefinition Width="18*"/><ColumnDefinition Width="18*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource FooterButtonStyle}" Content="GitHub" Click="GitHubButton_Click"/>
                        <TextBlock x:Name="FooterGroup" Grid.Column="1" Text="官方群: 630855391" Foreground="{StaticResource OnDarkSoftBrush}" FontSize="11.7" HorizontalAlignment="Center"/>
                        <Button Grid.Column="2" Style="{StaticResource FooterButtonStyle}" Content="加群" Click="JoinGroupButton_Click"/>
                        <TextBlock Grid.Column="3" Text="v0.2.5" Foreground="{StaticResource OnDarkSoftBrush}" FontFamily="Consolas" FontSize="12" HorizontalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
